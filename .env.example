# Alpaca (browser → dev proxy; omit on Vercel if using serverless only)
# VITE_ALPACA_API_KEY=
# VITE_ALPACA_SECRET_KEY=

# Local dev only: deployed app origin so /api/chat, /api/generate-portfolio, etc. resolve (no trailing slash).
# Do not set this on Vercel production unless you intend cross-origin API calls.
# VITE_API_ORIGIN=https://your-app.vercel.app
